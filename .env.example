# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/clipbandit
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/clipbandit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clipbandit

# Redis + Celery
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/0
AUTH_RATE_LIMIT_REDIS_DB=2
API_RATE_LIMIT_REDIS_DB=3

# Auth
NEXTAUTH_SECRET=changeme-generate-a-real-secret-in-production
NEXTAUTH_URL=http://localhost:3001
INTERNAL_API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Used by both /login and /signup Google OAuth buttons.
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
ADMIN_EMAIL=admin@clipbandit.com
ADMIN_PASSWORD=changeme123

# JWT (used by backend)
JWT_SECRET_KEY=changeme-jwt-secret-key-32-chars-min

# Public app URLs (used for OAuth callbacks/redirects)
# BACKEND_PUBLIC_URL must be an externally reachable absolute http(s) URL.
# OAuth callback URL shapes:
#   {BACKEND_PUBLIC_URL}/api/social/youtube/callback
#   {BACKEND_PUBLIC_URL}/api/social/x/callback
#   {BACKEND_PUBLIC_URL}/api/social/facebook/callback
#   {BACKEND_PUBLIC_URL}/api/social/instagram/callback
#   {BACKEND_PUBLIC_URL}/api/social/threads/callback
#   {BACKEND_PUBLIC_URL}/api/social/tiktok/callback
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Stripe Billing
# Never commit real Stripe keys.
STRIPE_BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREATOR_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ELITE_PRICE_ID=

# Backblaze B2 (S3-compatible API)
B2_KEY_ID=placeholder
B2_APPLICATION_KEY=placeholder
B2_BUCKET_NAME=placeholder
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
THUMBNAIL_DIR=/data/thumbnails
B2_BACKUP_ENABLED=false

# Optional aliases for backup-only B2 keys. Prefer the B2_KEY_ID and
# B2_APPLICATION_KEY values above unless using a separate backup-only key.
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=

# Anthropic (carousel generation primary provider)
ANTHROPIC_API_KEY=placeholder

# DeepSeek (clip copy + carousel generation fallback)
DEEPSEEK_API_KEY=placeholder
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SEC=30
CAROUSEL_CLAUDE_MODEL=claude-sonnet-4-6
CAROUSEL_RENDER_TIMEOUT_SECONDS=240
CAROUSEL_REFERENCE_IMAGE_MAX_MB=10
BANDIT_LM_API_KEY=
GOOGLE_AI_API_KEY=

# Social distribution
# Required for any social provider connection/token storage.
SOCIAL_TOKEN_ENCRYPTION_KEY=placeholder
SOCIAL_OAUTH_STATE_TTL_MINUTES=15

# Google OAuth credentials for YouTube provider.
# Never commit real values to git.
YOUTUBE_CLIENT_ID=placeholder
YOUTUBE_CLIENT_SECRET=placeholder

# Meta-family app credentials
# Provider-specific values are preferred:
#   FACEBOOK_APP_ID / FACEBOOK_APP_SECRET
#   INSTAGRAM_APP_ID / INSTAGRAM_APP_SECRET  (Instagram Login app credentials)
#   THREADS_APP_ID / THREADS_APP_SECRET
# If provider-specific values are not set, META_APP_ID / META_APP_SECRET are used as fallback.
FACEBOOK_APP_ID=placeholder
FACEBOOK_APP_SECRET=placeholder
INSTAGRAM_APP_ID=placeholder
INSTAGRAM_APP_SECRET=placeholder
THREADS_APP_ID=placeholder
THREADS_APP_SECRET=placeholder

# Shared fallback app credentials (optional if provider-specific values are set)
META_APP_ID=placeholder
META_APP_SECRET=placeholder
# Optional Graph API version override
META_GRAPH_API_VERSION=v21.0
# Optional Threads Graph API version override
THREADS_GRAPH_API_VERSION=v1.0

TIKTOK_CLIENT_KEY=placeholder
TIKTOK_CLIENT_SECRET=placeholder
TIKTOK_PUBLISH_POLL_INTERVAL_SECONDS=5
TIKTOK_PUBLISH_POLL_TIMEOUT_SECONDS=720

X_CLIENT_ID=placeholder
X_CLIENT_SECRET=placeholder

LINKEDIN_CLIENT_ID=placeholder
LINKEDIN_CLIENT_SECRET=placeholder

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
BACKUP_DIR=/opt/clipbandit/backups
BACKUP_RETENTION_DAYS=14
MAX_UPLOAD_SIZE_MB=5000
MAX_CONCURRENT_JOBS=2
YOUTUBE_IMPORT_MAX_PLAYLIST_ITEMS=50
YOUTUBE_IMPORT_CONCURRENCY=3
YTDLP_TIMEOUT_SECONDS=60
ENABLE_YOUTUBE_API_METADATA=false
YOUTUBE_API_KEY=placeholder
YOUTUBE_LOCAL_HELPER_TTL_MINUTES=15
YOUTUBE_IMPORT_ADMISSION_MODE=warn
YOUTUBE_IMPORT_MIN_FREE_DISK_GB=20
YOUTUBE_IMPORT_MAX_INGEST_QUEUE_DEPTH=100
YOUTUBE_IMPORT_MAX_ACTIVE_PER_USER=3
YOUTUBE_IMPORT_MAX_ACTIVE_GLOBAL=12
YOUTUBE_IMPORT_RATE_LIMIT_PER_HOUR=25
YOUTUBE_HELPER_SESSION_RATE_LIMIT_PER_HOUR=20
YOUTUBE_IMPORT_ADMISSION_STORAGE_PATH=/tmp/clipbandit-storage
WORKSPACE_LEASE_TTL_SECONDS=3600
WORKSPACE_CLEANUP_ENABLED=true
WORKSPACE_CLEANUP_DRY_RUN=true
WORKSPACE_CLEANUP_RETENTION_HOURS=24
WORKSPACE_CLEANUP_ORPHAN_GRACE_MINUTES=45
FAILED_IMPORT_CLEANUP_ENABLED=true
FAILED_IMPORT_CLEANUP_RETENTION_HOURS=24
FAILED_IMPORT_CLEANUP_DRY_RUN=false
STALE_QUEUED_UPLOAD_CLEANUP_ENABLED=true
STALE_QUEUED_UPLOAD_CLEANUP_RETENTION_HOURS=2
STALE_QUEUED_UPLOAD_CLEANUP_DRY_RUN=false
RAW_SOURCE_RETENTION_ENABLED=true
RAW_SOURCE_RETENTION_DAYS=30
STARTER_STORAGE_QUOTA_BYTES=5368709120
STARTER_STORAGE_HARD_STOP_BYTES=6442450944
EDITOR_MAX_ASSET_UPLOAD_BYTES=26214400
EDITOR_PREVIEW_PROXY_TIMEOUT_SECONDS=600
